{
  "name": "@base/ui",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./input/*": "./src/components/input/*/index.tsx",
    "./layout/*": "./src/components/layout/*/index.tsx",
    "./typography/*": "./src/components/typography/*/index.tsx",
    "./overlays/*": "./src/components/overlays/*/index.tsx",
    "./navigation/*": "./src/components/navigation/*/index.tsx",
    "./display/*": "./src/components/display/*/index.tsx",
    "./providers/*": "./src/components/providers/*/index.tsx",
    "./alpha/*": "./src/components/alpha/*/index.tsx",
    "./tokens/*.stylex": "./src/tokens/*.stylex.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@stylexjs/stylex": "^0.19.0",
    "@tabler/icons-react": "^3.44.0",
    "@uidotdev/usehooks": "^2.4.1",
    "motion": "^12.42.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "typescript": "^6.0.3"
  }
}
