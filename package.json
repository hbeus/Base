{
  "name": "base",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @base/web dev",
    "build": "pnpm --filter @base/web build",
    "start": "pnpm --filter @base/web start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "pnpm --filter @base/web test",
    "db:generate": "pnpm --filter @base/db generate",
    "db:migrate": "pnpm --filter @base/db migrate",
    "db:studio": "pnpm --filter @base/db studio"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1"
  }
}
